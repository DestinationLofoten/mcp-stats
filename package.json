{
  "name": "nordata",
  "version": "1.0.0",
  "description": "Norwegian public data pipeline, MCP server, and report agent",
  "private": true,
  "scripts": {
    "fetch:brreg": "ts-node fetchers/brreg.ts",
    "fetch:ssb": "ts-node fetchers/ssb.ts",
    "fetch:all": "ts-node fetchers/run-all.ts",
    "fetch:docs": "ts-node fetchers/documents.ts",
    "fetch:reddit": "ts-node fetchers/reddit.ts",
    "analyze:sentiment": "ts-node fetchers/analyze-sentiment.ts",
    "sync:drive": "ts-node fetchers/sync-drive.ts",
    "sync:drive:auth": "ts-node fetchers/sync-drive.ts --auth",
    "mcp": "ts-node mcp-server/index.ts",
    "mcp:build": "tsc && node dist/mcp-server/index.js",
    "report": "ts-node report-agent/agent.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "googleapis": "^171.4.0",
    "mammoth": "^1.12.0",
    "openai": "^6.38.0",
    "pdf-parse": "^1.1.1",
    "tiktoken": "^1.0.22",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
